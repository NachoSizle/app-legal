---
import LegalLayout from '../layouts/LegalLayout.astro'
import { APPS, LAST_UPDATED } from '../legal-config'

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`

const resources = [
  {
    title: 'Privacy Policy',
    description: 'Data, permissions, providers, purchases, and privacy requests.',
    path: 'privacy-policy',
  },
  {
    title: 'Terms of Use',
    description: 'Rules for using the app, Pro purchases, accounts, and availability.',
    path: 'terms-of-use',
  },
  {
    title: 'Support',
    description: 'Help, account deletion, subscriptions, backups, and contact details.',
    path: 'support',
  },
]
---

<LegalLayout
  title="Legal Directory"
  appName="App Legal"
  lastUpdated={LAST_UPDATED}
  description="Public legal and support pages for iOS apps."
  contentSurface={false}
  showHomeLink={false}
>
  <ul class="directory-list">
    {
      APPS.map((app) => (
        <li class="directory-card">
          <h2>{app.name}</h2>
          <p>{app.description}</p>
          <nav class="resource-list" aria-label={`${app.name} legal resources`}>
            {
              resources.map((resource) => (
                <a class="resource-link" href={`${base}apps/${app.slug}/${resource.path}/`}>
                  <span>
                    <strong>{resource.title}</strong>
                    <small>{resource.description}</small>
                  </span>
                  <span aria-hidden="true" class="resource-arrow">
                    &rarr;
                  </span>
                </a>
              ))
            }
          </nav>
        </li>
      ))
    }
  </ul>
</LegalLayout>
